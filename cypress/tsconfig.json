{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es2015", "dom", "dom.iterable", "esnext"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["cypress", "node"],
    "paths": {
      "@/*": ["../src/*"],
      "@prisma-generated": ["../prisma/generated/prisma/client"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../cypress.config.ts"
  ],
  "exclude": ["jest", "@types/jest"]
}
