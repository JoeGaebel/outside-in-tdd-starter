{
  "name": "outside-in-tdd-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint . -c oxlintrc.json && node bin/lint-test-patterns.mjs",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:studio": "npx prisma studio",
    "prisma:reset": "npx prisma migrate reset",
    "prisma:create-only": "npx prisma migrate dev --create-only",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "test:unit": "jest --selectProjects frontend backend --passWithNoTests",
    "test:unit:spec": "jest",
    "test:e2e": "./bin/run-cypress-tests.sh",
    "cypress:open": "./bin/run-cypress-tests.sh open",
    "cypress:run": "./bin/run-cypress-tests.sh",
    "cypress:test": "./bin/run-cypress-tests.sh --spec",
    "typecheck": "npx tsc --noEmit",
    "test:mutate": "node bin/mutate-changed.mjs",
    "test:mutate:file": "node bin/mutate-changed.mjs",
    "test:mutate:uncommitted": "node bin/mutate-changed.mjs --uncommitted"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "next": "16.1.6",
    "next-auth": "^4.24.11",
    "pg": "^8.15.6",
    "postcss": "^8.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@quramy/jest-prisma": "^1.8.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/jest-runner": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "cypress": "^14.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-fixed-jsdom": "^0.0.9",
    "msw": "^2.10.2",
    "node-mocks-http": "^1.17.2",
    "oxlint": "^1.49.0",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3"
  }
}
